# =============================================================================
# Graphynovus — Environment Variables
# Copy this file to `.env.local` and fill in the real values.
# =============================================================================

# --- Supabase (REQUIRED) -----------------------------------------------------
# Project settings → API → Project URL / anon public key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — only needed once we add server-side admin operations
# (cron jobs, bulk imports). Not referenced yet; safe to leave blank for MVP.
SUPABASE_SERVICE_ROLE_KEY=

# --- Google Gemini (REQUIRED) ------------------------------------------------
# https://aistudio.google.com/apikey — must have access to `gemini-2.0-flash-exp`.
GEMINI_API_KEY=

# --- App (OPTIONAL) ----------------------------------------------------------
# Used for absolute URLs in metadata / emails. Defaults to window.location in
# the browser and is not read by the server today. Set on Vercel to your
# production domain once deployed (e.g. https://graphynovus.vercel.app).
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Graphynovus

# --- Optional (Phase 2+) -----------------------------------------------------
# Redis cache for Entropy Score recomputation (PRD §6.1).
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# Alternative vector DB for Execution Memory (default is pgvector in Supabase).
PINECONE_API_KEY=
